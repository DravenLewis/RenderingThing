609         {\cf18 bool} sampleAdaptiveFocusDistance(PTexture depthTex, {\cf18 float}& outDistance)\{\par
610             {\cf19 if}(!depthTex || depthTex->getID() == 0)\{\par
611                 {\cf19 return} {\cf17 false};\par
612             \}\par
613 \par
614             {\cf18 int} width = 0;\par
615             {\cf18 int} height = 0;\par
616             GLint prevTexBinding = 0;\par
617             glGetIntegerv(GL_TEXTURE_BINDING_2D, &prevTexBinding);\par
618             glBindTexture(GL_TEXTURE_2D, depthTex->getID());\par
619             glGetTexLevelParameteriv(GL_TEXTURE_2D, 0, GL_TEXTURE_WIDTH, &width);\par
620             glGetTexLevelParameteriv(GL_TEXTURE_2D, 0, GL_TEXTURE_HEIGHT, &height);\par
621             {\cf19 if}(width <= 0 || height <= 0)\{\par
622                 glBindTexture(GL_TEXTURE_2D, {\cf17 static_cast<}GLuint{\cf17 >}(prevTexBinding));\par
623                 {\cf19 return} {\cf17 false};\par
624             \}\par
625 \par
626             {\cf18 size_t} pixelCount = {\cf17 static_cast<}{\cf18 size_t}{\cf17 >}(width) * {\cf17 static_cast<}{\cf18 size_t}{\cf17 >}(height);\par
627             {\cf19 if}(pixelCount == 0)\{\par
628                 glBindTexture(GL_TEXTURE_2D, {\cf17 static_cast<}GLuint{\cf17 >}(prevTexBinding));\par
629                 {\cf19 return} {\cf17 false};\par
630             \}\par
631             {\cf19 if}(adaptiveFocusDepthCpu.size() != pixelCount)\{\par
632                 adaptiveFocusDepthCpu.resize(pixelCount);\par
633             \}\par
634             {\cf19 if}(adaptiveFocusDepthCpu.empty())\{\par
635                 glBindTexture(GL_TEXTURE_2D, {\cf17 static_cast<}GLuint{\cf17 >}(prevTexBinding));\par
636                 {\cf19 return} {\cf17 false};\par
637             \}\par
638 \par
639             GLenum preReadErr = glGetError();\par
640             (void)preReadErr;\par
641             glGetTexImage(GL_TEXTURE_2D, 0, GL_DEPTH_COMPONENT, GL_FLOAT, adaptiveFocusDepthCpu.data());\par
642             GLenum readErr = glGetError();\par
643             glBindTexture(GL_TEXTURE_2D, {\cf17 static_cast<}GLuint{\cf17 >}(prevTexBinding));\par
644             {\cf19 if}(readErr != GL_NO_ERROR)\{\par
645                 {\cf19 return} {\cf17 false};\par
646             \}\par
647 \par
648             {\cf17 const} {\cf18 float} kSkyDepthCutoff = 0.9995f;\par
649             {\cf18 int} x = Math3D::Clamp({\cf17 static_cast<}{\cf18 int}{\cf17 >}(std::round(focusUv.x * {\cf17 static_cast<}{\cf18 float}{\cf17 >}(width - 1))), 0, width - 1);\par
650             {\cf18 int} y = Math3D::Clamp({\cf17 static_cast<}{\cf18 int}{\cf17 >}(std::round(focusUv.y * {\cf17 static_cast<}{\cf18 float}{\cf17 >}(height - 1))), 0, height - 1);\par
651             {\cf18 float} depth = adaptiveFocusDepthCpu[{\cf17 static_cast<}{\cf18 size_t}{\cf17 >}(y) * {\cf17 static_cast<}{\cf18 size_t}{\cf17 >}(width) + {\cf17 static_cast<}{\cf18 size_t}{\cf17 >}(x)];\par
652             {\cf19 if}(!std::isfinite(depth) || depth >= kSkyDepthCutoff)\{\par
653                 {\cf19 return} {\cf17 false};\par
654             \}\par
655             outDistance = linearizeDepthCpu(depth);\par
656             {\cf19 return} std::isfinite(outDistance) && outDistance > 0.0f;\par
657         \}\par
