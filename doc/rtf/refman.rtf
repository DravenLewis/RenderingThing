227         {\cf17 static} std::shared_ptr<FrameBuffer> CreateGBuffer({\cf18 int} width, {\cf18 int} height)\{\par
228             {\cf17 auto} fbuffer = std::make_shared<FrameBuffer>(width, height);\par
229 \par
230             fbuffer->gbufferAttachments.clear();\par
231             fbuffer->gbufferAttachments.reserve(3);\par
232 \par
233             {\cf17 auto} createAttachment = [&](GLenum internalFormat, GLenum format, GLenum type) -> PTexture \{\par
234                 GLuint texId = 0;\par
235                 glGenTextures(1, &texId);\par
236                 glBindTexture(GL_TEXTURE_2D, texId);\par
237                 glTexImage2D(GL_TEXTURE_2D, 0, internalFormat, width, height, 0, format, type, NULL);\par
238                 glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_NEAREST);\par
239                 glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_NEAREST);\par
240                 glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);\par
241                 glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);\par
242                 glBindTexture(GL_TEXTURE_2D, 0);\par
243                 {\cf19 return} Texture::CreateFromExisting(texId, width, height, {\cf17 true});\par
244             \};\par
245 \par
246             fbuffer->bind();\par
247 \par
248             \{\par
249                 GBufferAttachment albedo;\par
250                 albedo.internalFormat = GL_RGBA8;\par
251                 albedo.format = GL_RGBA;\par
252                 albedo.type = GL_UNSIGNED_BYTE;\par
253                 albedo.texture = createAttachment(albedo.internalFormat, albedo.format, albedo.type);\par
254                 glFramebufferTexture2D(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT0, GL_TEXTURE_2D, albedo.texture->getID(), 0);\par
255                 fbuffer->gbufferAttachments.push_back(albedo);\par
256             \}\par
257 \par
258             \{\par
259                 GBufferAttachment normal;\par
260                 normal.internalFormat = GL_RGBA16F;\par
261                 normal.format = GL_RGBA;\par
262                 normal.type = GL_FLOAT;\par
263                 normal.texture = createAttachment(normal.internalFormat, normal.format, normal.type);\par
264                 glFramebufferTexture2D(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT1, GL_TEXTURE_2D, normal.texture->getID(), 0);\par
265                 fbuffer->gbufferAttachments.push_back(normal);\par
266             \}\par
267 \par
268             \{\par
269                 GBufferAttachment position;\par
270                 {\cf20 // Large receivers (e.g. 200x200 ground planes) need full precision to avoid deferred-light banding.}\par
271                 position.internalFormat = GL_RGBA32F;\par
272                 position.format = GL_RGBA;\par
273                 position.type = GL_FLOAT;\par
274                 position.texture = createAttachment(position.internalFormat, position.format, position.type);\par
275                 glFramebufferTexture2D(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT2, GL_TEXTURE_2D, position.texture->getID(), 0);\par
276                 fbuffer->gbufferAttachments.push_back(position);\par
277             \}\par
278 \par
279             GLenum drawBuffers[3] = \{ GL_COLOR_ATTACHMENT0, GL_COLOR_ATTACHMENT1, GL_COLOR_ATTACHMENT2 \};\par
280             glDrawBuffers(3, drawBuffers);\par
281             glReadBuffer(GL_COLOR_ATTACHMENT0);\par
282 \par
283             GLenum status = glCheckFramebufferStatus(GL_FRAMEBUFFER);\par
284             {\cf19 if}(status != GL_FRAMEBUFFER_COMPLETE)\{\par
285                 std::string error;\par
286                 {\cf19 switch}(status)\{\par
287                     {\cf19 case} GL_FRAMEBUFFER_INCOMPLETE_ATTACHMENT:         error = {\cf22 "Incomplete Attachment"}; {\cf19 break};\par
288                     {\cf19 case} GL_FRAMEBUFFER_INCOMPLETE_MISSING_ATTACHMENT: error = {\cf22 "Missing Attachment"}; {\cf19 break};\par
289                     {\cf19 case} GL_FRAMEBUFFER_UNSUPPORTED:                   error = {\cf22 "Unsupported Format"}; {\cf19 break};\par
290                     {\cf19 default}:                                           error = {\cf22 "Unknown Error"}; {\cf19 break};\par
291                 \}\par
292                 LogBot.Log(LOG_ERRO, {\cf22 "[FrameBuffer] GBuffer Error: %s (Code: %u)"}, error.c_str(), status);\par
293             \}\par
294 \par
295             fbuffer->unbind();\par
296 \par
297             {\cf19 return} fbuffer;\par
298         \}\par
