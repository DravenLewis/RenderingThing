384 {\cf17 class }DepthOfFieldEffect : {\cf17 public} Graphics::PostProcessing::PostProcessingEffect \{\par
385     {\cf17 private}:\par
386         std::shared_ptr<ShaderProgram> shader;\par
387         {\cf18 bool} compileAttempted = {\cf17 false};\par
388         {\cf18 float} resolvedFocusDistance = 8.0f;\par
389         {\cf18 float} resolvedFocusRange = 4.0f;\par
390         {\cf18 bool} focusAdaptationInitialized = {\cf17 false};\par
391         {\cf18 float} smoothedFocusDistance = 8.0f;\par
392         {\cf18 float} smoothedFocusRange = 4.0f;\par
393         {\cf18 float} focusPullBackRate = 10.0f;\par
394         {\cf18 float} focusPushOutRate = 3.0f;\par
395         {\cf18 float} focusFallbackRate = 2.0f;\par
396         {\cf18 bool} debugAdaptiveCenterValid = {\cf17 false};\par
397         {\cf18 float} debugAdaptiveCenterDistance = 0.0f;\par
398         {\cf18 bool} debugAdaptiveRayValid = {\cf17 false};\par
399         {\cf18 float} debugAdaptiveRayDistance = 0.0f;\par
400         {\cf18 bool} debugAdaptiveUsedFallback = {\cf17 false};\par
401         {\cf18 float} debugAdaptiveTargetDistance = 0.0f;\par
402         {\cf18 float} debugAdaptiveFallbackDistance = 0.0f;\par
403         std::chrono::steady_clock::time_point lastFocusAdaptationTime = std::chrono::steady_clock::now();\par
404         std::vector<float> adaptiveFocusDepthCpu;\par
405         {\cf17 const} std::string DOF_FRAG_SHADER = R{\cf22 "(}\par
406 {\cf22             #version 330 core}\par
407 {\cf22 }\par
408 {\cf22             out vec4 FragColor;}\par
409 {\cf22             in vec2 TexCoords;}\par
410 {\cf22 }\par
411 {\cf22             uniform sampler2D screenTexture;}\par
412 {\cf22             uniform sampler2D depthTexture;}\par
413 {\cf22             uniform vec2 u_texelSize;}\par
414 {\cf22             uniform float u_focusDistance;}\par
415 {\cf22             uniform float u_focusRange;}\par
416 {\cf22             uniform float u_focusBandWidth;}\par
417 {\cf22             uniform float u_blurRamp;}\par
418 {\cf22             uniform float u_blurDistanceLerp;}\par
419 {\cf22             uniform float u_blurStrength;}\par
420 {\cf22             uniform float u_maxBlurPx;}\par
421 {\cf22             uniform int u_sampleCount;}\par
422 {\cf22             uniform int u_debugCocView;}\par
423 {\cf22             uniform int u_adaptiveFocusEnabled;}\par
424 {\cf22             uniform vec2 u_focusUv;}\par
425 {\cf22             uniform float u_nearPlane;}\par
426 {\cf22             uniform float u_farPlane;}\par
427 {\cf22 }\par
433             float linearizeDepth(float depth)\{\par
434                 float z = depth * 2.0 - 1.0;\par
435                 return (2.0 * u_nearPlane * u_farPlane) / max((u_farPlane + u_nearPlane) - (z * (u_farPlane - u_nearPlane)), 0.0001);\par
436             \}\par
437 \par
442             float resolveFocusDistance()\{\par
443                 if(u_adaptiveFocusEnabled == 0)\{\par
444                     return u_focusDistance;\par
445                 \}\par
446 \par
447                 const float kSkyDepthCutoff = 0.9995;\par
448                 vec2 clampedFocusUv = clamp(u_focusUv, vec2(0.0), vec2(1.0));\par
449                 float centerDepth = texture(depthTexture, clampedFocusUv).r;\par
450                 if(centerDepth < kSkyDepthCutoff)\{\par
451                     return linearizeDepth(centerDepth);\par
452                 \}\par
453 \par
454                 vec2 fallbackTaps[8] = vec2[](\par
455                     vec2( 1.0,  0.0),\par
456                     vec2(-1.0,  0.0),\par
457                     vec2( 0.0,  1.0),\par
458                     vec2( 0.0, -1.0),\par
459                     vec2( 2.0,  0.0),\par
460                     vec2(-2.0,  0.0),\par
461                     vec2( 0.0,  2.0),\par
462                     vec2( 0.0, -2.0)\par
463                 );\par
464 \par
465                 float accum = 0.0;\par
466                 float weight = 0.0;\par
467                 for(int i = 0; i < 8; ++i)\{\par
468                     vec2 sampleUv = clamp(clampedFocusUv + (fallbackTaps[i] * u_texelSize), vec2(0.0), vec2(1.0));\par
469                     float sampleDepth = texture(depthTexture, sampleUv).r;\par
470                     if(sampleDepth >= kSkyDepthCutoff)\{\par
471                         continue;\par
472                     \}\par
473                     accum += linearizeDepth(sampleDepth);\par
474                     weight += 1.0;\par
475                 \}\par
476 \par
477                 if(weight <= 0.0001)\{\par
478                     return u_focusDistance;\par
479                 \}\par
480                 return accum / weight;\par
481             \}\par
482 \par
492             vec3 gatherBlur(vec2 uv, float radiusPx, int sampleCount, float centerLinearDepth, float blurAmount)\{\par
493                 vec2 dirs[8] = vec2[](\par
494                     vec2( 1.0,  0.0),\par
495                     vec2(-1.0,  0.0),\par
496                     vec2( 0.0,  1.0),\par
497                     vec2( 0.0, -1.0),\par
498                     vec2( 0.707,  0.707),\par
499                     vec2(-0.707,  0.707),\par
500                     vec2( 0.707, -0.707),\par
501                     vec2(-0.707, -0.707)\par
502                 );\par
503 \par
504                 vec3 accum = texture(screenTexture, uv).rgb;\par
505                 float weight = 1.0;\par
506                 int loops = clamp(sampleCount, 1, 8);\par
507                 float baseDepthTolerance = max(u_focusRange * 0.35, 0.25);\par
508                 // Keep blur relaxation continuous from the first blur contribution so large flats\par
509                 // do not show a distance "knee" where blur behavior abruptly changes.\par
510                 float blurRelax = smoothstep(0.0, 1.0, clamp(blurAmount, 0.0, 1.0));\par
511                 float relaxedDepthTolerance = mix(baseDepthTolerance, max(baseDepthTolerance * 4.0, 1.5), blurRelax);\par
512                 for(int i = 0; i < loops; ++i)\{\par
513                     vec2 offset = dirs[i] * radiusPx * u_texelSize;\par
514                     vec2 sampleUv = clamp(uv + offset, vec2(0.0), vec2(1.0));\par
515                     vec3 sampleColor = texture(screenTexture, sampleUv).rgb;\par
516                     float sampleLinearDepth = linearizeDepth(texture(depthTexture, sampleUv).r);\par
517                     float depthDelta = abs(sampleLinearDepth - centerLinearDepth);\par
518                     float depthWeight = 1.0 - smoothstep(0.0, relaxedDepthTolerance, depthDelta);\par
519                     depthWeight = mix(depthWeight, 1.0, blurRelax * 0.55);\par
520                     accum += sampleColor * depthWeight;\par
521                     weight += depthWeight;\par
522                 \}\par
523                 return accum / max(weight, 0.0001);\par
524             \}\par
525 \par
529             void main() \{\par
530                 vec4 base = texture(screenTexture, TexCoords);\par
531                 float depth = texture(depthTexture, TexCoords).r;\par
532                 float linearDepth = linearizeDepth(depth);\par
533                 float focusDistance = resolveFocusDistance();\par
534 \par
535                 float focusRange = max(u_focusRange, 0.001);\par
536                 float depthDelta = linearDepth - focusDistance;\par
537                 float nearBoost = (depthDelta < 0.0) ? 1.15 : 1.0;\par
538                 // Smooth CoC falloff prevents a harsh in-focus strip while keeping\par
539                 // a clear focal region around the resolved distance.\par
540                 float absDepthDelta = abs(depthDelta);\par
541                 float focusBandWidth = max(u_focusBandWidth, 0.05);\par
542                 float focusSigma = max(focusRange * focusBandWidth, 0.02);\par
543                 float coc = 1.0 - exp(-(absDepthDelta * absDepthDelta) / (2.0 * focusSigma * focusSigma));\par
544                 coc = clamp(coc * nearBoost, 0.0, 1.0);\par
545                 float blurRamp = max(u_blurRamp, 0.05);\par
546                 float cocCurve = pow(coc, blurRamp);\par
547                 float blurDistanceLerp = clamp(u_blurDistanceLerp, 0.0, 1.0);\par
548                 float cocBlend = mix(cocCurve, coc, blurDistanceLerp);\par
549                 float strength = max(u_blurStrength, 0.0);\par
550                 float blurRadius = cocBlend * max(u_maxBlurPx, 0.0) * strength;\par
551                 // Use stronger blend than radius scaling so clearly out-of-focus regions\par
552                 // don't remain overly crisp at moderate blurStrength values.\par
553                 float blurAmount = clamp(cocBlend * clamp(strength * 1.8, 0.0, 1.0), 0.0, 1.0);\par
554                 if(u_debugCocView != 0)\{\par
555                     vec3 focusColor = vec3(0.10, 0.95, 0.20);\par
556                     vec3 nearColor = vec3(0.18, 0.55, 1.00);\par
557                     vec3 farColor = vec3(1.00, 0.42, 0.12);\par
558                     vec3 sideColor = (depthDelta < 0.0) ? nearColor : farColor;\par
559                     vec3 cocColor = mix(focusColor, sideColor, coc);\par
560                     cocColor *= mix(0.45, 1.0, blurAmount);\par
561                     FragColor = vec4(cocColor, 1.0);\par
562                     return;\par
563                 \}\par
564                 vec3 blurred = gatherBlur(TexCoords, blurRadius, u_sampleCount, linearDepth, blurAmount);\par
565                 vec3 color = mix(base.rgb, blurred, blurAmount);\par
566                 FragColor = vec4(color, base.a);\par
567             \}\par
568         )";\par
