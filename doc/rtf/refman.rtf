169             GLenum status = glCheckFramebufferStatus(GL_FRAMEBUFFER);\par
170             {\cf19 if} (status != GL_FRAMEBUFFER_COMPLETE) \{\par
171                 std::string error;\par
172                 {\cf19 switch} (status) \{\par
173                     {\cf19 case} GL_FRAMEBUFFER_INCOMPLETE_ATTACHMENT:         error = {\cf22 "Incomplete Attachment"}; {\cf19 break};\par
174                     {\cf19 case} GL_FRAMEBUFFER_INCOMPLETE_MISSING_ATTACHMENT: error = {\cf22 "Missing Attachment"}; {\cf19 break};\par
175                     {\cf19 case} GL_FRAMEBUFFER_UNSUPPORTED:                   error = {\cf22 "Unsupported Format"}; {\cf19 break};\par
176                     {\cf19 default}:                                           error = {\cf22 "Unknown Error"}; {\cf19 break};\par
177                 \}\par
178                 LogBot.Log(LOG_ERRO, {\cf22 "[FrameBuffer] FBO Error: %s (Code: %u)"}, error.c_str(), status);\par
179             \}\par
180 \par
181             unbind();\par
182         \}\par
