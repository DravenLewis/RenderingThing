1074         {\cf18 void} computeAdaptiveScales(PTexture tex, {\cf18 float}& outThresholdScale, {\cf18 float}& outIntensityScale, {\cf18 float}& outExposureScale)\{\par
1075             outThresholdScale = smoothedThresholdScale;\par
1076             outIntensityScale = smoothedIntensityScale;\par
1077             outExposureScale = smoothedExposureScale;\par
1078             {\cf19 if}(!adaptiveBloom)\{\par
1079                 adaptationInitialized = {\cf17 false};\par
1080                 adaptedLuminance = 0.35f;\par
1081                 filteredLuminance = 0.35f;\par
1082                 smoothedThresholdScale = 1.0f;\par
1083                 smoothedIntensityScale = 1.0f;\par
1084                 smoothedExposureScale = 1.0f;\par
1085                 outThresholdScale = smoothedThresholdScale;\par
1086                 outIntensityScale = smoothedIntensityScale;\par
1087                 outExposureScale = smoothedExposureScale;\par
1088                 {\cf19 return};\par
1089             \}\par
1090 \par
1091             {\cf18 float} observedLuminance = adaptedLuminance;\par
1092             {\cf19 if}(!sampleSceneLuminance(tex, observedLuminance))\{\par
1093                 {\cf19 return};\par
1094             \}\par
1095 \par
1096             {\cf17 auto} now = std::chrono::steady_clock::now();\par
1097             {\cf19 if}(!adaptationInitialized)\{\par
1098                 adaptedLuminance = observedLuminance;\par
1099                 filteredLuminance = observedLuminance;\par
1100                 smoothedThresholdScale = 1.0f;\par
1101                 smoothedIntensityScale = 1.0f;\par
1102                 smoothedExposureScale = 1.0f;\par
1103                 adaptationInitialized = {\cf17 true};\par
1104                 lastAdaptationTime = now;\par
1105             \}{\cf19 else}\{\par
1106                 {\cf18 float} dt = std::chrono::duration<float>(now - lastAdaptationTime).count();\par
1107                 dt = Math3D::Clamp(dt, 0.001f, 0.25f);\par
1108                 lastAdaptationTime = now;\par
1109 \par
1110                 {\cf20 // First, filter noisy per-frame luminance shifts (camera motion over high-contrast edges).}\par
1111                 {\cf17 const} {\cf18 float} observedFilterRate = 5.0f;\par
1112                 {\cf17 const} {\cf18 float} observedAlpha = 1.0f - std::exp(-observedFilterRate * dt);\par
1113                 filteredLuminance += (observedLuminance - filteredLuminance) * observedAlpha;\par
1114 \par
1115                 {\cf20 // Then move the "eye adaptation" state toward filtered luminance.}\par
1116                 {\cf17 const} {\cf18 float} adaptationRateUp = 1.35f;\par
1117                 {\cf17 const} {\cf18 float} adaptationRateDown = 0.95f;\par
1118                 {\cf17 const} {\cf18 float} adaptationRate = (filteredLuminance > adaptedLuminance) ? adaptationRateUp : adaptationRateDown;\par
1119                 {\cf17 const} {\cf18 float} adaptationAlpha = 1.0f - std::exp(-adaptationRate * dt);\par
1120                 adaptedLuminance += (filteredLuminance - adaptedLuminance) * adaptationAlpha;\par
1121 \par
1122                 {\cf18 float} ratio = Math3D::Clamp(filteredLuminance / Math3D::Max(adaptedLuminance, 0.0001f), 0.5f, 2.5f);\par
1123                 {\cf19 if}(std::abs(std::log2(ratio)) < 0.06f)\{\par
1124                     ratio = 1.0f;\par
1125                 \}\par
1126 \par
1127                 {\cf17 const} {\cf18 float} targetExposureScale = Math3D::Clamp(std::pow(ratio, 0.16f), 0.92f, 1.16f);\par
1128                 {\cf17 const} {\cf18 float} targetIntensityScale = Math3D::Clamp(std::pow(ratio, 0.30f), 0.72f, 1.55f);\par
1129                 {\cf17 const} {\cf18 float} targetThresholdScale = Math3D::Clamp(std::pow(ratio, -0.18f), 0.78f, 1.22f);\par
1130 \par
1131                 {\cf17 const} {\cf18 float} outputSmoothingRate = 4.2f;\par
1132                 {\cf17 const} {\cf18 float} outputAlpha = 1.0f - std::exp(-outputSmoothingRate * dt);\par
1133                 smoothedExposureScale += (targetExposureScale - smoothedExposureScale) * outputAlpha;\par
1134                 smoothedIntensityScale += (targetIntensityScale - smoothedIntensityScale) * outputAlpha;\par
1135                 smoothedThresholdScale += (targetThresholdScale - smoothedThresholdScale) * outputAlpha;\par
1136             \}\par
1137 \par
1138             outThresholdScale = smoothedThresholdScale;\par
1139             outIntensityScale = smoothedIntensityScale;\par
1140             outExposureScale = smoothedExposureScale;\par
1141         \}\par
