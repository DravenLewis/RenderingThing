462         {\cf20 // Helper functions for understanding the order.}\par
463 \par
464         std::shared_ptr<FrameBuffer> getDisplayBuffer()\{\par
465             {\cf19 return} getFront();\par
466         \}\par
467 \par
472         std::shared_ptr<FrameBuffer> getEditBuffer()\{\par
473             {\cf19 return} getMiddle();\par
474         \}\par
475 \par
480         std::shared_ptr<FrameBuffer> getDrawBuffer()\{\par
481             {\cf19 return} getBack();\par
482         \}\par
483 \par
484         {\cf20 // ===================================================}\par
485 \par
486         {\cf18 void} setFront(std::shared_ptr<FrameBuffer> framePtr)\{\par
487             chain.setAtIndex(0,framePtr);\par
488         \}\par
489 \par
494         {\cf18 void} setMiddle(std::shared_ptr<FrameBuffer> framePtr)\{\par
495             chain.setAtIndex(1,framePtr);\par
496         \}\par
497 \par
502         {\cf18 void} setBack(std::shared_ptr<FrameBuffer> framePtr)\{\par
503             chain.setAtIndex(2,framePtr);\par
504         \}\par
505 \par
509         {\cf18 void} swapBuffers()\{\par
510             {\cf17 auto} frontBuffer = getFront();\par
511             {\cf17 auto} middleBuffer = getMiddle();\par
512             {\cf17 auto} backBuffer = getBack();\par
513 \par
514             setFront(middleBuffer);\par
515             setMiddle(backBuffer);\par
516             setBack(frontBuffer);\par
517         \}\par
518 \par
524         {\cf18 void} resizeBuffers({\cf18 int} width, {\cf18 int} height)\{\par
525             chain.resizeBuffers(width, height);\par
526         \}\par
527 \};\par
