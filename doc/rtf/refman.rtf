135                 {\cf19 for}({\cf17 auto}& attachment : gbufferAttachments)\{\par
136                     {\cf19 if}(!attachment.texture) {\cf19 continue};\par
137                     glBindTexture(GL_TEXTURE_2D, attachment.texture->getID());\par
138                     glTexImage2D(\par
