232                 vec4 color = texture(screenTexture, TexCoords);\par
233 \par
234                 if(u_applyDeband != 0)\{\par
235                     vec2 texelSize = 1.0 / vec2(textureSize(screenTexture, 0));\par
236                     vec3 rightColor = texture(screenTexture, clamp(TexCoords + vec2(texelSize.x, 0.0), vec2(0.0), vec2(1.0))).rgb;\par
237                     vec3 upColor = texture(screenTexture, clamp(TexCoords + vec2(0.0, texelSize.y), vec2(0.0), vec2(1.0))).rgb;\par
238 \par
239                     float centerLuma = luma(color.rgb);\par
240                     float gradient = abs(centerLuma - luma(rightColor)) + abs(centerLuma - luma(upColor));\par
241                     float smoothRegion = 1.0 - smoothstep(0.002, 0.030, gradient);\par
242 \par
