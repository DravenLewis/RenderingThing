916     {\cf17 private}:\par
917         std::shared_ptr<ShaderProgram> shader;\par
918         {\cf18 bool} compileAttempted = {\cf17 false};\par
919         {\cf17 const} std::string BLOOM_FRAG_SHADER = R{\cf22 "(}\par
920 {\cf22             #version 330 core}\par
921 {\cf22 }\par
922 {\cf22             out vec4 FragColor;}\par
923 {\cf22             in vec2 TexCoords;}\par
924 {\cf22 }\par
925 {\cf22             uniform sampler2D screenTexture;}\par
926 {\cf22             uniform vec2 u_texelSize;}\par
927 {\cf22             uniform float u_threshold;}\par
928 {\cf22             uniform float u_softKnee;}\par
929 {\cf22             uniform float u_intensity;}\par
930 {\cf22             uniform float u_radiusPx;}\par
931 {\cf22             uniform int u_sampleCount;}\par
932 {\cf22             uniform vec3 u_tint;}\par
933 {\cf22             uniform float u_exposureScale;}\par
934 {\cf22 }\par
935 {\cf22             const vec2 kPoisson[12] = vec2[](}\par
936 {\cf22                 vec2(-0.326, -0.406),}\par
937 {\cf22                 vec2(-0.840, -0.074),}\par
938 {\cf22                 vec2(-0.696,  0.457),}\par
939 {\cf22                 vec2(-0.203,  0.621),}\par
940 {\cf22                 vec2( 0.962, -0.195),}\par
941 {\cf22                 vec2( 0.473, -0.480),}\par
942 {\cf22                 vec2( 0.519,  0.767),}\par
943 {\cf22                 vec2( 0.185, -0.893),}\par
944 {\cf22                 vec2( 0.507,  0.064),}\par
945 {\cf22                 vec2( 0.896,  0.412),}\par
946 {\cf22                 vec2(-0.322,  0.951),}\par
950                 vec2(-0.720,  0.631)\par
951             );\par
952 \par
958             vec3 prefilterBright(vec3 color)\{\par
959                 float brightness = max(color.r, max(color.g, color.b));\par
960                 float threshold = max(u_threshold, 0.0);\par
961                 float knee = max(threshold * max(u_softKnee, 0.0001), 0.00001);\par
962                 float soft = clamp(brightness - threshold + knee, 0.0, 2.0 * knee);\par
963                 soft = (0.25 / knee) * soft * soft;\par
964                 float hard = max(brightness - threshold, 0.0);\par
965                 float contribution = max(hard, soft) / max(brightness, 0.0001);\par
966                 return color * contribution;\par
967             \}\par
968 \par
972             void main() \{\par
973                 float exposureScale = max(u_exposureScale, 0.0);\par
974                 vec3 base = texture(screenTexture, TexCoords).rgb;\par
975 \par
976                 int count = clamp(u_sampleCount, 1, 12);\par
977                 float radiusPx = max(u_radiusPx, 0.0);\par
978                 vec3 bloomAccum = prefilterBright(base);\par
979                 float weightSum = 1.0;\par
980 \par
981                 for(int i = 0; i < 12; ++i)\{\par
982                     if(i >= count)\{\par
983                         break;\par
984                     \}\par
985                     float ringT = (float(i) + 0.5) / float(count);\par
986                     float radialScale = mix(0.35, 1.0, ringT);\par
987                     float weight = mix(1.0, 0.35, ringT);\par
988                     vec2 offset = kPoisson[i] * radiusPx * radialScale * u_texelSize;\par
989                     vec2 uvA = clamp(TexCoords + offset, vec2(0.0), vec2(1.0));\par
990                     vec2 uvB = clamp(TexCoords - offset, vec2(0.0), vec2(1.0));\par
991                     vec3 sampleA = prefilterBright(texture(screenTexture, uvA).rgb * exposureScale);\par
992                     vec3 sampleB = prefilterBright(texture(screenTexture, uvB).rgb * exposureScale);\par
993                     bloomAccum += (sampleA + sampleB) * weight;\par
994                     weightSum += 2.0 * weight;\par
995                 \}\par
996 \par
997                 vec3 bloom = (bloomAccum / max(weightSum, 0.0001));\par
998                 bloom *= max(u_intensity, 0.0) * u_tint;\par
999 \par
1000                 vec3 color = base + bloom;\par
1001                 FragColor = vec4(max(color, vec3(0.0)), 1.0);\par
1002             \}\par
