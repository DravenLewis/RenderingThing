158         {\cf18 void} attachTexture(PTexture tex)\{\par
159 \par
160             this->texturePtr = tex;\par
161 \par
162             bind();\par
163             glFramebufferTexture2D(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT0, GL_TEXTURE_2D, tex->getID(), 0);\par
