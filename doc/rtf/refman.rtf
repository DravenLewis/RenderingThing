201                                     .Norm(normal)\par
202                                     .UV(u, 1.0f - v);\par
203                 {\cf18 int} outIndex = -1;\par
204                 factory.addVertex(vertex, &outIndex);\par
205                 indices[(size_t)stack * ({\cf18 size_t})(slices + 1) + ({\cf18 size_t})slice] = outIndex;\par
206             \}\par
207         \}\par
208 \par
209         {\cf19 for}({\cf18 int} stack = 0; stack < stacks; ++stack)\{\par
210             {\cf19 for}({\cf18 int} slice = 0; slice < slices; ++slice)\{\par
211                 {\cf18 int} i00 = indices[(size_t)stack * ({\cf18 size_t})(slices + 1) + ({\cf18 size_t})slice];\par
212                 {\cf18 int} i01 = indices[(size_t)stack * ({\cf18 size_t})(slices + 1) + ({\cf18 size_t})(slice + 1)];\par
213                 {\cf18 int} i10 = indices[(size_t)(stack + 1) * (size_t)(slices + 1) + (size_t)slice];\par
214                 {\cf18 int} i11 = indices[(size_t)(stack + 1) * (size_t)(slices + 1) + (size_t)(slice + 1)];\par
215 \par
216                 {\cf19 if}(stack == 0)\{\par
217                     factory.defineFace(i00, i11, i10);\par
218                 \}{\cf19 else} {\cf19 if}(stack == (stacks - 1))\{\par
219                     factory.defineFace(i00, i01, i10);\par
220                 \}{\cf19 else}\{\par
221                     factory.defineFace(i00, i11, i10);\par
222                     factory.defineFace(i00, i01, i11);\par
223                 \}\par
224             \}\par
225         \}\par
226 \par
