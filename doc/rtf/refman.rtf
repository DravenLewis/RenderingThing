1019         {\cf18 bool} sampleSceneLuminance(PTexture tex, {\cf18 float}& outLuminance)\{\par
1020             {\cf19 if}(!tex || tex->getID() == 0 || tex->getWidth() <= 0 || tex->getHeight() <= 0)\{\par
1021                 {\cf19 return} {\cf17 false};\par
1022             \}\par
