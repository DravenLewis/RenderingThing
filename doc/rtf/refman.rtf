46         FrameBuffer({\cf18 int} width, {\cf18 int} height) : width(width), height(height) \{\par
47             glGenFramebuffers(1, &fboID);\par
48             \par
49             {\cf20 // 1. Create the Depth Texture}\par
50             {\cf20 // We do this manually here (or you could add a helper in Texture.h)}\par
51             depthTexture = std::make_shared<Texture>();\par
52             {\cf20 // Note: We don't set width/height on the Texture object here manually }\par
53             {\cf20 // unless your Texture class requires it.}\par
54 \par
55             GLuint tid;\par
56             glGenTextures(1, &tid);\par
57             depthTexture->getID() = tid;\par
58 \par
59             {\cf20 // DEBUG CHECK}\par
60             {\cf19 if}(depthTexture->getID() == 0) \{\par
61                 LogBot.Log(LOG_FATL, {\cf22 "[FrameBuffer] CRITICAL: glGenTextures failed for Depth Texture!"});\par
62             \}\par
63 \par
64             glBindTexture(GL_TEXTURE_2D, depthTexture->getID());\par
65 \par
66             {\cf20 // GL_DEPTH_COMPONENT24 is standard for precision}\par
67             glTexImage2D(GL_TEXTURE_2D, 0, GL_DEPTH_COMPONENT24, width, height, 0, GL_DEPTH_COMPONENT, GL_FLOAT, NULL);\par
68             \par
69             {\cf20 // Essential Texture Parameters for Depth}\par
70             {\cf20 // Linear filtering keeps post-process depth lookups (SSAO/DOF) stable across pixel edges.}\par
71             glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR);\par
72             glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);\par
73             glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_BORDER); \par
74             glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_BORDER);\par
75             \par
76             {\cf20 // Border color for depth (white = far away) prevents artifacts at screen edges}\par
77             {\cf18 float} borderColor[] = \{ 1.0f, 1.0f, 1.0f, 1.0f \};\par
78             glTexParameterfv(GL_TEXTURE_2D, GL_TEXTURE_BORDER_COLOR, borderColor);\par
79 \par
80             {\cf20 // 2. Attach Depth Texture to FBO}\par
81             bind();\par
82             glFramebufferTexture2D(GL_FRAMEBUFFER, GL_DEPTH_ATTACHMENT, GL_TEXTURE_2D, depthTexture->getID(), 0);\par
83             \par
84             {\cf20 // Note: We are currently NOT complete because we have no Color buffer yet.}\par
85             {\cf20 // Screen class attaches color later via attachTexture().}\par
86             {\cf20 // If you want to use this for Shadow Mapping (Depth Only), you need to tell GL to draw no color:}\par
87             {\cf20 // glDrawBuffer(GL_NONE); glReadBuffer(GL_NONE);}\par
88 \par
89             {\cf20 // Crucial: Tell OpenGL we aren't drawing to color YET}\par
90             glDrawBuffer(GL_NONE);\par
91             glReadBuffer(GL_NONE);\par
92             \par
93             unbind();\par
94         \}\par
