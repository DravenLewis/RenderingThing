202                 return dot(c, vec3(0.299, 0.587, 0.114));\par
203             \}\par
204 \par
211             float interleavedGradientNoise(vec2 p, float frame)\{\par
212                 vec2 jitter = vec2(frame * 0.75487765, frame * 0.56984026);\par
213                 return fract(52.9829189 * fract(dot(p + jitter, vec2(0.06711056, 0.00583715))));\par
214             \}\par
215 \par
222             float triangularNoise(vec2 p, float frame)\{\par
223                 float a = interleavedGradientNoise(p + vec2(0.5, 0.25), frame);\par
224                 float b = interleavedGradientNoise(p + vec2(1.25, 2.75), frame + 17.0);\par
225                 return a - b;\par
