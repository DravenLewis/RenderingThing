200                 // Treat near-far depth as background/sky and skip AO to avoid horizon halos.\par
201                 const float kSkyDepthCutoff = 0.9995;\par
202                 if(centerDepthRaw >= kSkyDepthCutoff)\{\par
203                     FragColor = base;\par
204                     return;\par
205                 \}\par
206                 float centerDepth = linearizeDepth(centerDepthRaw);\par
207 \par
208                 float radiusPx = max(u_radiusPx, 0.25);\par
209                 float depthRadius = max(u_depthRadius, 0.00005);\par
210                 int count = clamp(u_sampleCount, 1, 16);\par
211                 // Use pixel-stable noise to avoid UV-space stripe patterns on large flat surfaces.\par
212                 float angle = hash12(floor(gl_FragCoord.xy)) * 6.2831853;\par
213                 float sinAngle = sin(angle);\par
214                 float cosAngle = cos(angle);\par
215 \par
216                 // Scale thresholds with distance and local depth slope for temporal stability.\par
217                 // Avoid derivative-based slope (dFdx/dFdy), which can introduce primitive-edge seams.\par
218                 float depthScaleTarget = clamp(centerDepth * 0.08, 1.0, 32.0);\par
219                 // Smoothly ramp depth scaling to avoid a visible contour where distance scaling kicks in.\par
220                 float depthScaleBlend = smoothstep(4.0, 28.0, centerDepth);\par
221                 float depthScale = mix(1.0, depthScaleTarget, depthScaleBlend);\par
222                 float adaptiveDepthRadius = depthRadius * depthScale;\par
223                 float depthRightRaw = texture(depthTexture, clamp(TexCoords + vec2(u_texelSize.x, 0.0), vec2(0.0), vec2(1.0))).r;\par
224                 float depthUpRaw = texture(depthTexture, clamp(TexCoords + vec2(0.0, u_texelSize.y), vec2(0.0), vec2(1.0))).r;\par
225                 float depthRight = (depthRightRaw >= kSkyDepthCutoff) ? centerDepth : linearizeDepth(depthRightRaw);\par
226                 float depthUp = (depthUpRaw >= kSkyDepthCutoff) ? centerDepth : linearizeDepth(depthUpRaw);\par
227                 float depthSlope = abs(depthRight - centerDepth) + abs(depthUp - centerDepth);\par
228                 float baseBias = max(u_bias * depthScale, adaptiveDepthRadius * 0.10);\par
229 \par
230                 float occ = 0.0;\par
231                 float weightSum = 0.0;\par
232                 for(int i = 0; i < count; ++i)\{\par
233                     float ringT = (float(i) + 0.5) / float(count);\par
234                     vec2 poisson = kPoisson[i];\par
235                     vec2 rotated = vec2(\par
236                         (poisson.x * cosAngle) - (poisson.y * sinAngle),\par
237                         (poisson.x * sinAngle) + (poisson.y * cosAngle)\par
238                     );\par
239 \par
240                     for(int mirror = 0; mirror < 2; ++mirror)\{\par
241                         vec2 direction = (mirror == 0) ? rotated : -rotated;\par
242                         vec2 pixelOffset = direction * radiusPx * ringT;\par
243                         vec2 uv = TexCoords + (pixelOffset * u_texelSize);\par
244                         if(uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0)\{\par
245                             continue;\par
246                         \}\par
247                         float sampleDepthRaw = texture(depthTexture, uv).r;\par
248                         if(sampleDepthRaw >= kSkyDepthCutoff)\{\par
249                             continue;\par
250                         \}\par
251                         float sampleDepth = linearizeDepth(sampleDepthRaw);\par
252 \par
253                         float depthDelta = centerDepth - sampleDepth;\par
254                         float slopeAllowance = depthSlope * length(pixelOffset);\par
255                         float adjustedDelta = depthDelta - (baseBias + slopeAllowance);\par
256                         float sampleOcc = smoothstep(0.0, adaptiveDepthRadius, adjustedDelta);\par
257                         float radialBias = 1.0 - smoothstep(0.35, 1.0, ringT);\par
258                         sampleOcc *= mix(1.0, 1.35, radialBias);\par
259                         // Weight by raw geometric proximity so non-occluding neighbors still normalize.\par
260                         float rangeWeight = 1.0 - smoothstep(0.0, adaptiveDepthRadius * 2.5, abs(depthDelta));\par
261                         occ += sampleOcc * rangeWeight;\par
262                         weightSum += rangeWeight;\par
263                     \}\par
264                 \}\par
265 \par
266                 occ = clamp(occ / max(weightSum, 0.0001), 0.0, 1.0);\par
267                 occ = pow(occ, 0.85);\par
268                 float effectiveIntensity = pow(max(u_intensity, 0.0), 0.6);\par
269                 // Keep a floor so SSAO cannot collapse the whole frame into near-black.\par
270                 float ao = clamp(1.0 - (occ * effectiveIntensity), 0.35, 1.0);\par
271 \par
272                 float giFactor = (1.0 - ao);\par
273                 giFactor = giFactor * giFactor * u_giBoost;\par
274                 vec3 giBounce = base.rgb * giFactor;\par
275                 vec3 finalColor = (base.rgb * ao) + giBounce;\par
276                 FragColor = vec4(finalColor, base.a);\par
277             \}\par
278         )";\par
279 \par
284         {\cf18 bool} ensureCompiled()\{\par
285             {\cf19 if}(!shader)\{\par
286                 {\cf19 return} {\cf17 false};\par
287             \}\par
288             {\cf19 if}(shader->getID() != 0)\{\par
