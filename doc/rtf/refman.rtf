598             {\cf18 float} z = (depth * 2.0f) - 1.0f;\par
599             {\cf19 return} (2.0f * nearPlane * farPlane) /\par
600                    Math3D::Max((farPlane + nearPlane) - (z * (farPlane - nearPlane)), 0.0001f);\par
