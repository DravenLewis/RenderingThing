130                 glTexImage2D(GL_TEXTURE_2D, 0, GL_DEPTH_COMPONENT24, width, height, 0, GL_DEPTH_COMPONENT, GL_FLOAT, NULL);\par
131                 glBindTexture(GL_TEXTURE_2D, 0);\par
132             \}\par
